<UserControl
    x:Class="NewSpartan.App.UI.Controls.Titlebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NewSpartan.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="400">

    <Grid Height="32">
        <Grid.Background>
            <AcrylicBrush
            BackgroundSource="HostBackdrop"
            TintColor="#202020"
            TintOpacity="0.3"
            FallbackColor="#202020"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid x:Name="DragRegion" Grid.Row="0" Grid.Column="0" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch">
                <Image Width="24" Height="24" x:Name="Icon"
                    Source="ms-appx:///Assets/StoreLogo.png" Stretch="Uniform" VerticalAlignment="Center" Margin="5, 4, 0, 4"/>
                <TextBlock x:Name="Title" Text="NewSpartan Browser"
                    VerticalAlignment="Center"
                    Margin="5,0,0,0"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="Content" HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="0, 0, 138, 0">
        </Grid>
    </Grid>
</UserControl>
