<UserControl
    x:Class="NewSpartan.App.ControlBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NewSpartan.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="400">

    <Grid Height="40">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal">
            <Button x:Name="BackButton" Width="40" Height="40" ToolTipService.ToolTip="Back" Click="BackButton_Click" IsEnabled="False">
                <FontIcon Glyph="&#xE72B;" FontSize="14" />
            </Button>

            <Button x:Name="ForwardButton" Width="40" Height="40" ToolTipService.ToolTip="Forward" Click="ForwardButton_Click" IsEnabled="False">
                <FontIcon Glyph="&#xE72A;" FontSize="14" />
            </Button>

            <Button x:Name="ReloadButton" Width="40" Height="40" ToolTipService.ToolTip="Reload" Click="ReloadButton_Click">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>
        </StackPanel>

        <Grid Grid.Column="1" Height="40">
            <AutoSuggestBox x:Name="SearchBox"
                VerticalAlignment="Stretch"
                VerticalContentAlignment="Center"
                PlaceholderText="Enter a web address"
                QueryIcon="Forward"
                QuerySubmitted="SearchBox_QuerySubmitted"
                TextChanged="SearchBox_TextChanged">
                <AutoSuggestBox.Resources>
                    <Thickness x:Key="TextControlThemePadding">12,11,0,11</Thickness>
                    <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                </AutoSuggestBox.Resources>
            </AutoSuggestBox>
        </Grid>
    </Grid>
</UserControl>
